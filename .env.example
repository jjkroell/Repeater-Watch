# ── Authentication ──────────────────────────────────────────────────────────
# Leave both empty to disable login entirely.
# Use setup_auth.py to set a bcrypt-hashed password (recommended).
# MESHCORE_PASSWORD_HASH is preferred; MESHCORE_PASSWORD (plaintext) is fallback.
MESHCORE_PASSWORD_HASH=
MESHCORE_PASSWORD=
MESHCORE_SECRET_KEY=

# ── Serial (MeshCore radio) ──────────────────────────────────────────────────
# /dev/ttyV0 is the SerialMux virtual port for RepeaterWatch polling
MESHCORE_SERIAL_PORT=/dev/ttyV0
MESHCORE_SERIAL_BAUD=115200
MESHCORE_SERIAL_TIMEOUT=5

# ── Polling ──────────────────────────────────────────────────────────────────
MESHCORE_POLL_INTERVAL=300

# ── Database ─────────────────────────────────────────────────────────────────
MESHCORE_DB_PATH=/opt/RepeaterWatch/meshcore.db
MESHCORE_RETENTION_DAYS=30

# ── Flask ────────────────────────────────────────────────────────────────────
MESHCORE_HOST=0.0.0.0
MESHCORE_PORT=5000
MESHCORE_DEBUG=0

# ── Firmware flash ───────────────────────────────────────────────────────────
# Set to the by-id path of your Ikoka/XIAO device
MESHCORE_FLASH_SERIAL_PORT=/dev/serial/by-id/usb-Seeed_Studio_XIAO_nRF52840_XXXXXXXXXXXX-if00
MESHCORE_FIRMWARE_UPLOAD_DIR=/tmp/meshcore-fw

# ── Web terminal ─────────────────────────────────────────────────────────────
# /dev/ttyV2 is the SerialMux virtual port for the serial terminal
MESHCORE_TERMINAL_SERIAL_PORT=/dev/ttyV2
MESHCORE_TERMINAL_SERIAL_BAUD=115200

# ── Sensors ──────────────────────────────────────────────────────────────────
# Set 1 to enable a sensor, 0 to disable.
# Use the Manage Sensors modal in the dashboard, or edit manually here.
# MESHCORE_SENSOR_POLL is auto-managed — set to 1 if any sensor is enabled.
MESHCORE_SENSOR_INA3221=0
MESHCORE_SENSOR_BME280=0
MESHCORE_SENSOR_LIS2DW12=0
MESHCORE_SENSOR_AS3935=0
MESHCORE_SENSOR_BQ24074=0
MESHCORE_SENSOR_POLL=0
